@model IEnumerable<appSegurancas.Models.Seguranca>

    @{ ViewData["Title"] = "Painel de Aprovados"; }

    <h2>SeguranÁas Aprovados</h2>
   
    <form asp-action="PesquisarSegurancaAprovado" method="get">
        <div class="input-group mb-3">
            <button class=" input-group-text" type="submit">
                <i class="bi bi-search"></i>
            </button>
            <input type="text" name="pesquisa" class="form-control" />
            <a class=" input-group-text" type="button" asp-for="Admin" asp-action="VisualizarSegurancas">
                <i class="bi bi-x-lg"></i>
            </a>
        </div>
    </form>
        
    
    

    <table class="table table-striped mt-4">
        <thead>
            <tr>
                <th>Nome</th>
                <th>CPF</th>
                <th>MatrÌcula</th>
                <th>AÁes</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
        {

            if (@item.cpf != "12345678912") {

            <tr>
                <!--login do administrador-->

                <td>@item.nome @item.sobreNome</td>
                <td>@item.cpf</td>
                <td>@item.matricula</td>


                <td>
                    <!--asp route id serve pra colocar o id desse seguranca como argumento do mÈtodo UploadContracheque-->
                    <a asp-action="VerContrachequeSeguranca" asp-route-id="@item.id" class="btn btn-sm btn-jw">
                        Ver Contracheques
                    </a>
                </td>
            </tr>
            }

        }
        </tbody>
    </table>
    <a asp-for="Admin" asp-action="PainelAdmin" class="btn btn-secondary">Voltar</a>
