@model appSegurancas.Models.LoginViewModel

@{ ViewData["Title"] = "Acesso ao Sistema"; }

<h2>Login Administrador</h2>

<div class="row">
    <div class="col-md-4">
        <form asp-action="Admin" method="post">
            <div asp-validation-summary="All" class="text-danger"></div>

            <div class="form-group mb-3">
                <!--asp-for serve para encontrar a variavel na classe de Login -->
                <label>Login</label>
                <input name="login" class="form-control" />
            </div>

            <div class="form-group mb-3">
                <label>Senha</label>
                <input type="password" name="senha" class="form-control" />
            </div>

            <button type="submit" class="btn btn-success">Entrar</button>

        </form>


    </div>
</div>