@model DetalhesContrachequeViewModel

    @{ ViewData["Title"] = "Contracheques do Seguran�a"; }


    <h2>Contracheques de @Model.nomeSeguranca</h2>
    <a asp-action="VisualizarSegurancas" class="btn btn-sm btn-secondary">
        <i class="bi bi-arrow-left"></i> Voltar
    </a>
    <a asp-action="UploadContracheque" asp-route-id="@Model.segurancaId" class="btn btn-sm btn-success">
        <i class="bi bi-plus-lg"></i> Novo Contracheque</a>
    <table class="table table-hover mt-4">
        <thead class="table-dark">
            <tr>

                <th>Mês</th>
                <th>Ano</th>
                <th>Ações</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.contracheques)
        {
            <tr>
                <td>@item.mesUpload</td>
                <td>@item.anoUpload</td>
                <td>
                    <form asp-action="ExcluirContracheque" asp-route-id="@item.id" method="post">
                        <button type="submit" class="btn btn-sm btn-danger btn-confirmar">
                            Excluir
                        </button>
                    </form>
                </td>
            </tr>
        }
        </tbody>
    </table>

    
