@model appSegurancas.Models.LoginViewModel

@{ ViewData["Title"] = "Acesso ao Sistema"; }

<h2>Login</h2>

<div class="row">
    <div class="col-md-4">
        <form asp-action="Login" method="post">
            <div asp-validation-summary="All" class="text-danger"></div>

            <div class="form-group mb-3">
                <!--asp-for serve para encontrar a variavel na classe de Login -->
                <label asp-for="cpf"></label>
                <input asp-for="cpf" class="form-control" />
            </div>

            <div class="form-group mb-3">
                <label asp-for="senha"></label>
                <input asp-for="senha" class="form-control" />
            </div>

            <button type="submit" class="btn btn-success">Entrar</button>
            <button class="btn btn-success"><a class="nav-link" asp-area="" asp-controller="Seguranca" asp-action="Cadastro">Cadastrar</a></button>

        </form>
        <div>
            <p> </p>
            <!--gambiarra-->
        </div>

       
    </div>
</div>