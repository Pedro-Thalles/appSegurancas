@model IEnumerable<appSegurancas.Models.Contracheque>

    @{ ViewData["Title"] = "Meus Contracheques"; }

    <h2>Meus Pagamentos</h2>

    <table class="table table-hover mt-4">
        <thead class="table-dark">
            <tr>
                <th>MÍs</th>
                <th>Ano</th>
                <th>AÁes</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
        {
            <tr>
                <td>@item.mesUpload</td>
                <td>@item.anoUpload</td>
                <td>
                    <a asp-action="DownloadContracheque"
                       asp-route-id="@item.id"
                       class="btn btn-sm btn-danger">
                        <i class="bi bi-file-earmark-pdf"></i> PDF
                    </a>
                </td>
            </tr>
        }   
        </tbody>
    </table>
