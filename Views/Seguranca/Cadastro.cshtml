@model appSegurancas.Models.Seguranca

@{
    ViewData["Title"] = "Cadastro de Segurança";
}
<!--asp-for serve para encontrar a variavel na classe de Seguranca -->
<h2>Cadastrar Novo Segurança</h2>

<div class="row">
    <div class="col-md-6">
        <form asp-action="Cadastro" method="post">
            <div class="form-group mb-3">
                <label asp-for="nome" class="control-label"></label>
                <input asp-for="nome" class="form-control" />
            </div>

            <div class="form-group mb-3">
                <label asp-for="sobreNome" class="control-label"></label>
                <input asp-for="sobreNome" class="form-control" />
            </div>

            <div class="form-group mb-3">
                <label asp-for="cpf" class="control-label"></label>
                <input asp-for="cpf" class="form-control" />
            </div>

            <div class="form-group mb-3">
                <label asp-for="matricula" class="control-label"></label>
                <input asp-for="matricula" class="form-control" />
            </div>

            <div class="form-group mb-3">
                <label asp-for="email" class="control-label"></label>
                <input asp-for="email" class="form-control" />
            </div>

            <div class="form-group mb-4">
                <label>Senha</label>
                <input name="senhaPura" type="password" class="form-control" />
                <small class="text-muted">A senha será criptografada antes de salvar.</small>
            </div>

            <button type="submit" class="btn btn-primary">Finalizar Cadastro</button>
        </form>
    </div>
</div>